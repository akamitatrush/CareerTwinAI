// CareerTwin AI — schema inicial (Fase 1).
// PostgreSQL + Prisma. Auth.js v5 com adapter Prisma usa User/Account/Session/VerificationToken.
// Cascata em tudo que pendura de User → "Apagar tudo" é um único delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Auth.js (Prisma adapter) ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Monitoramento: cron-digest checa para nao mandar 2x na mesma semana.
  lastDigestAt  DateTime?
  digestEnabled Boolean   @default(true)

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  snapshots     ScoreSnapshot[]
  consents      Consent[]
  dataSources   DataSource[]
  applications  Application[]
  tailoredCvs   TailoredCv[]
  notifications Notification[]
  assessments   AssessmentResult[]
  evidence      Evidence[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ CareerTwin ============

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  nome        String?
  cargoAtual  String?
  senioridade String?
  targetRole  String?
  skills      String[] @default([])
  rawCv       String?  @db.Text
  perfilJson  Json?

  // LinkedIn (texto colado, parseado pra estrutura).
  linkedinRaw  String? @db.Text
  linkedinJson Json?

  // Portfolio (GitHub username + projetos extraidos + sites pessoais).
  githubUser    String?
  portfolioJson Json?

  // Welcome flow. firstDiagnosisAt e setado no primeiro ScoreSnapshot persistido
  // (detecta "primeira vez de verdade"). welcomedAt e setado quando o usuario
  // dismissa o banner welcome no /dashboard — junto, decidem se o banner aparece.
  firstDiagnosisAt DateTime?
  welcomedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id         String   @id @default(cuid())
  userId     String
  role       String
  overall    Int
  subScores  Json
  perfilJson Json?
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gaps      Gap[]
  planItems PlanItem[]

  @@index([userId, createdAt])
}

model Gap {
  id              String    @id @default(cuid())
  snapshotId      String
  habilidade      String
  frequencia      String?
  porque          String?   @db.Text
  microacao       String?   @db.Text
  impactoDimensao String?
  impactoPontos   Int?
  completedAt     DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model PlanItem {
  id          String     @id @default(cuid())
  snapshotId  String
  semana      Int
  foco        String?
  titulo      String
  impacto     String?    @db.Text
  esforco     String?
  status      PlanStatus @default(pendente)
  completedAt DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, semana])
}

enum PlanStatus {
  pendente
  feita
}

enum ConsentSource {
  CV_PASTE
  CV_PDF
  CV_DOCX
  LINKEDIN_EXPORT
  LINKEDIN_OIDC
  LINKEDIN_PASTE
  PORTFOLIO_GITHUB
  PORTFOLIO_URL
  WEEKLY_DIGEST
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id         String            @id @default(cuid())
  userId     String
  titulo     String
  empresa    String
  local      String?
  url        String?
  salario    String?
  source     String?
  status     ApplicationStatus @default(SAVED)
  notes      String?           @db.Text
  savedAt    DateTime          @default(now())
  appliedAt  DateTime?
  rejectedAt DateTime?
  offerAt    DateTime?
  updatedAt  DateTime          @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      ApplicationEvent[]
  tailoredCvs TailoredCv[]

  @@index([userId, status])
  @@index([userId, updatedAt])
}

model ApplicationEvent {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus?
  note          String?            @db.Text
  occurredAt    DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, occurredAt])
}

model Consent {
  id          String        @id @default(cuid())
  userId      String
  source      ConsentSource
  grantedAt   DateTime      @default(now())
  revokedAt   DateTime?
  payloadHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source])
}

model DataSource {
  id         String        @id @default(cuid())
  userId     String
  kind       ConsentSource
  label      String
  sizeBytes  Int?
  ingestedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ingestedAt])
}

// Notificacoes in-app. Geradas pontualmente quando eventos importantes
// acontecem (microacao concluida, novo snapshot salvo, status de candidatura
// alterado, digest enviado). readAt=null => unread. Cascade no userId pra
// que "apagar tudo" leve junto. Indices duplos: timeline (userId,createdAt)
// e contador de unread (userId,readAt).
model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?
  meta      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

enum NotificationKind {
  GAP_COMPLETED
  PLAN_ITEM_COMPLETED
  SCORE_UPDATED
  DIGEST_SENT
  APPLICATION_STATUS
  WELCOME
}

// Resultado de mini-assessments de autoconhecimento (DISC-lite, Valores, Ikigai).
// scoresJson tem shape livre por tipo (ver lib/assessments/definitions.js).
// USO INFORMACIONAL — nao sao diagnosticos clinicos. Cascade no userId leva tudo
// junto em "apagar minha conta". Indice composto pra buscar o resultado mais
// recente por kind por user (groupBy/findFirst com orderBy).
model AssessmentResult {
  id          String         @id @default(cuid())
  userId      String
  kind        AssessmentKind
  scoresJson  Json
  insights    String?        @db.Text
  completedAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, completedAt])
}

enum AssessmentKind {
  DISC_LITE
  VALORES
  IKIGAI
}

// Evidencias de competencia — usuario DEMONSTRA skills (nao so declara) com
// cases/projetos/metricas. Cada Evidence vincula um conjunto de skills (mesma
// sintaxe de Profile.skills) a uma narrativa concreta com URL/periodo/metrica
// opcionais. Skills-first: recrutador acredita em evidencia especifica, nao
// em declaracao generica. Cascade no userId pra "apagar minha conta" levar
// junto. Indice (userId,createdAt) atende a listagem ordenada cronologicamente.
model Evidence {
  id          String       @id @default(cuid())
  userId      String
  kind        EvidenceKind
  title       String
  description String       @db.Text
  skills      String[]     @default([])
  metricLabel String?
  metricValue String?
  url         String?
  whenLabel   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum EvidenceKind {
  PROJECT
  CASE
  PUBLICATION
  CERTIFICATION
  AWARD
  CONTRIBUTION
}

// Historico de CVs adaptados pra vagas especificas. Cada chamada a /api/tailor
// que vier de um user logado gera um registro aqui. applicationId opcional
// permite tailor ad-hoc (sem vincular a Application do funil). onDelete:SetNull
// no applicationId garante que apagar uma Application nao apaga o historico.
model TailoredCv {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  vagaTitulo    String
  vagaEmpresa   String?
  beforeText    String   @db.Text
  afterText     String   @db.Text
  bullets       Json?
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
