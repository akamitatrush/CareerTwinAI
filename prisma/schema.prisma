// CareerTwin AI — schema inicial (Fase 1).
// PostgreSQL + Prisma. Auth.js v5 com adapter Prisma usa User/Account/Session/VerificationToken.
// Cascata em tudo que pendura de User → "Apagar tudo" é um único delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Auth.js (Prisma adapter) ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Monitoramento: cron-digest checa para nao mandar 2x na mesma semana.
  lastDigestAt  DateTime?
  digestEnabled Boolean   @default(true)

  // Daily briefing — cron-daily-briefing checa pra nao mandar 2x em 18h.
  // Compartilha o flag digestEnabled (1 toggle, 2 cadencias). Quando user
  // desliga digestEnabled, ambos cron (weekly + daily) param de enviar.
  lastDailyBriefingAt DateTime?

  // Welcome email — setado quando sendWelcomeEmail() despacha com sucesso.
  // Garante idempotencia: se ja enviou, no-op (mesmo se o cliente bater no
  // /api/auth/welcome-sent multiplas vezes). Null = ainda nao foi enviado.
  welcomeEmailSentAt DateTime?

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  snapshots     ScoreSnapshot[]
  consents      Consent[]
  dataSources   DataSource[]
  applications  Application[]
  tailoredCvs   TailoredCv[]
  notifications Notification[]
  assessments   AssessmentResult[]
  evidence      Evidence[]
  subscription  Subscription?
  usageMeters   UsageMeter[]
  billingEvents BillingEvent[]
  auditLogs     AuditLog[]
  outcomes      Outcome[]
  achievements  Achievement[]
  dailyQuests   DailyQuest[]
  funnelEntries FunnelEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ CareerTwin ============

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  nome        String?
  cargoAtual  String?
  senioridade String?
  targetRole  String?
  skills      String[] @default([])
  rawCv       String?  @db.Text
  perfilJson  Json?

  // LGPD — storage limitation: rawCv/linkedinRaw tem TTL de 90 dias.
  // rawCvExpiresAt e setado no upsert (analyze/upload). Cron diario apaga
  // rawCv/linkedinRaw quando expiresAt < now e marca rawCvRedactedAt.
  // perfilJson/linkedinJson (estruturados, anonimizaveis) ficam — sao o "gemeo".
  rawCvExpiresAt  DateTime?
  rawCvRedactedAt DateTime?

  // LinkedIn (texto colado, parseado pra estrutura).
  linkedinRaw           String?   @db.Text
  // LGPD storage limitation: linkedinRaw tambem expira em 90 dias.
  // Coluna dedicada (separada de rawCvExpiresAt) porque linkedin e CV podem
  // ser atualizados em momentos distintos — cada um carrega seu proprio TTL.
  // Cron redact-cv apaga linkedinRaw quando linkedinRawExpiresAt < now e
  // marca linkedinRawRedactedAt. linkedinJson (estruturado) fica.
  linkedinRawExpiresAt  DateTime?
  linkedinRawRedactedAt DateTime?
  linkedinJson          Json?

  // Portfolio (GitHub username + projetos extraidos + sites pessoais).
  githubUser    String?
  portfolioJson Json?

  // Welcome flow. firstDiagnosisAt e setado no primeiro ScoreSnapshot persistido
  // (detecta "primeira vez de verdade"). welcomedAt e setado quando o usuario
  // dismissa o banner welcome no /dashboard — junto, decidem se o banner aparece.
  firstDiagnosisAt DateTime?
  welcomedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id         String   @id @default(cuid())
  userId     String
  role       String
  overall    Int
  subScores  Json
  perfilJson Json?
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gaps      Gap[]
  planItems PlanItem[]

  @@index([userId, createdAt])
}

model Gap {
  id              String    @id @default(cuid())
  snapshotId      String
  habilidade      String
  frequencia      String?
  porque          String?   @db.Text
  microacao       String?   @db.Text
  impactoDimensao String?
  impactoPontos   Int?
  completedAt     DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model PlanItem {
  id          String     @id @default(cuid())
  snapshotId  String
  semana      Int
  foco        String?
  titulo      String
  impacto     String?    @db.Text
  esforco     String?
  status      PlanStatus @default(pendente)
  completedAt DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, semana])
}

enum PlanStatus {
  pendente
  feita
}

enum ConsentSource {
  CV_PASTE
  CV_PDF
  CV_DOCX
  LINKEDIN_EXPORT
  LINKEDIN_OIDC
  LINKEDIN_PASTE
  PORTFOLIO_GITHUB
  PORTFOLIO_URL
  WEEKLY_DIGEST
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id         String            @id @default(cuid())
  userId     String
  titulo     String
  empresa    String
  local      String?
  url        String?
  salario    String?
  source     String?
  status     ApplicationStatus @default(SAVED)
  notes      String?           @db.Text
  savedAt    DateTime          @default(now())
  appliedAt  DateTime?
  rejectedAt DateTime?
  offerAt    DateTime?
  updatedAt  DateTime          @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      ApplicationEvent[]
  tailoredCvs TailoredCv[]

  @@index([userId, status])
  @@index([userId, updatedAt])
}

model ApplicationEvent {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus?
  note          String?            @db.Text
  occurredAt    DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, occurredAt])
}

model Consent {
  id          String        @id @default(cuid())
  userId      String
  source      ConsentSource
  grantedAt   DateTime      @default(now())
  revokedAt   DateTime?
  payloadHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source])
}

model DataSource {
  id         String        @id @default(cuid())
  userId     String
  kind       ConsentSource
  label      String
  sizeBytes  Int?
  ingestedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ingestedAt])
}

// Notificacoes in-app. Geradas pontualmente quando eventos importantes
// acontecem (microacao concluida, novo snapshot salvo, status de candidatura
// alterado, digest enviado). readAt=null => unread. Cascade no userId pra
// que "apagar tudo" leve junto. Indices duplos: timeline (userId,createdAt)
// e contador de unread (userId,readAt).
model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?
  meta      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

enum NotificationKind {
  GAP_COMPLETED
  PLAN_ITEM_COMPLETED
  SCORE_UPDATED
  DIGEST_SENT
  APPLICATION_STATUS
  WELCOME
  DAILY_BRIEFING
  ACHIEVEMENT_UNLOCKED
}

// Resultado de mini-assessments de autoconhecimento (DISC-lite, Valores, Ikigai).
// scoresJson tem shape livre por tipo (ver lib/assessments/definitions.js).
// USO INFORMACIONAL — nao sao diagnosticos clinicos. Cascade no userId leva tudo
// junto em "apagar minha conta". Indice composto pra buscar o resultado mais
// recente por kind por user (groupBy/findFirst com orderBy).
model AssessmentResult {
  id          String         @id @default(cuid())
  userId      String
  kind        AssessmentKind
  scoresJson  Json
  insights    String?        @db.Text
  completedAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, completedAt])
}

enum AssessmentKind {
  DISC_LITE
  VALORES
  IKIGAI
}

// Evidencias de competencia — usuario DEMONSTRA skills (nao so declara) com
// cases/projetos/metricas. Cada Evidence vincula um conjunto de skills (mesma
// sintaxe de Profile.skills) a uma narrativa concreta com URL/periodo/metrica
// opcionais. Skills-first: recrutador acredita em evidencia especifica, nao
// em declaracao generica. Cascade no userId pra "apagar minha conta" levar
// junto. Indice (userId,createdAt) atende a listagem ordenada cronologicamente.
model Evidence {
  id          String       @id @default(cuid())
  userId      String
  kind        EvidenceKind
  title       String
  description String       @db.Text
  skills      String[]     @default([])
  metricLabel String?
  metricValue String?
  url         String?
  whenLabel   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum EvidenceKind {
  PROJECT
  CASE
  PUBLICATION
  CERTIFICATION
  AWARD
  CONTRIBUTION
}

// Knowledge base vetorizada pro RAG real (pgvector + Voyage AI embeddings).
// embedding = vetor 1024-dim semantico do `content`. contentHash (sha256 dos
// primeiros 32 chars do hex) garante idempotencia da ingestao: rodar 2x nao
// duplica. tipo `vector` requer extensao pgvector (criada na migration).
// `Unsupported` porque Prisma nao tem mapping nativo pra vector — leitura/escrita
// passa por $queryRaw/$executeRaw com cast ::vector.
model KnowledgeChunk {
  id          String                       @id @default(cuid())
  contentHash String                       @unique
  topic       String
  audience    String[]                     @default([])
  content     String                       @db.Text
  source      String
  tags        String[]                     @default([])
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([topic])
}

// ============ Billing (Stripe Phase 1+2) ============

// Subscription: relacao 1:1 com User. planId guarda o plano logico (free,
// pro_monthly, pro_yearly, team_monthly) — facilita auditar sem ir no Stripe.
// stripeCustomerId/stripeSubscriptionId tornam-se UNIQUE depois que webhook
// confirma assinatura; nullables porque user pode existir sem nunca ter
// passado pelo Stripe (free). currentPeriodEnd e atualizado em todo evento
// subscription.updated; quando vence sem renovacao, status cai pra CANCELED
// via webhook. cancelAtPeriodEnd reflete intencao do user via Customer Portal.
// Cascade no userId pra "apagar tudo" remover historico de assinatura junto.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  planId               String             @default("free")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

// UsageMeter: contador (userId, feature, periodKey) com unique pra upsert atomico.
// periodKey="2026-06" pra features mensais ("analyze", "tailor", "interview");
// "2026-06-22" (YYYY-MM-DD) pra diarias ("opportunities"). Periodo muda
// naturalmente sem cron — basta sufixar pelo periodo atual no dia da consulta.
// Cron mensal limpa registros >3 meses (housekeeping). Index (userId, periodKey)
// atende dashboard "uso do mes" sem full-scan.
model UsageMeter {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  count     Int      @default(0)
  // Telemetria de custo LLM: incrementada em trackTokenUsage apos chamada de
  // LLM. costUsd e Decimal(10,6) pra suportar fracoes < $0.000001 (Voyage AI
  // embeddings sao $0.06/1M tokens => ~$0.00000006 por token). Hard-cap diario
  // por plano em checkDailyBudget defende contra runaway cost de attacker.
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  costUsd   Decimal  @default(0) @db.Decimal(10, 6)
  periodKey String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodKey])
  @@index([userId, periodKey])
}

// BillingEvent: log auditavel de eventos Stripe processados. stripeEventId UNIQUE
// garante idempotencia — webhooks da Stripe sao retried; segundo processamento
// pega P2002 e retorna 200 sem reaplicar efeito. payload contem o data.object
// (subscription/invoice/etc) sem sanitizar — Stripe nao envia PII de outros
// users, somente os do customer dono. userId nullable pra eventos pre-customer
// (signup pendente) e onDelete:SetNull preserva auditoria quando user e apagado
// (LGPD: deixar rastro de cobrancas e legitimo).
//
// payload nullable: cron /api/cron/redact-billing limpa payload > 12 meses
// (LGPD storage limitation). stripeEventId+type+processedAt continuam pra audit.
model BillingEvent {
  id            String   @id @default(cuid())
  userId        String?
  stripeEventId String   @unique
  type          String
  payload       Json?
  processedAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type, processedAt])
}

// Historico de CVs adaptados pra vagas especificas. Cada chamada a /api/tailor
// que vier de um user logado gera um registro aqui. applicationId opcional
// permite tailor ad-hoc (sem vincular a Application do funil). onDelete:SetNull
// no applicationId garante que apagar uma Application nao apaga o historico.
model TailoredCv {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  vagaTitulo    String
  vagaEmpresa   String?
  beforeText    String   @db.Text
  afterText     String   @db.Text
  bullets       Json?
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// ============ Audit Log (LGPD/OWASP A09) ============

// AuditLog: trace de eventos sensiveis. Resolve gap A09 (Security Logging &
// Monitoring) do audit OWASP. Cada evento carrega userId (nullable pra acoes
// de sistema/anonimas), IP hasheado (LGPD: nao raw — sha256+salt), action
// (enum tipado), target (recurso afetado) e meta sanitizado (sem PII raw).
// onDelete:SetNull preserva auditoria quando user e apagado — LGPD permite
// reter rastros minimos legitimos pra defesa de direitos (ANPD investigation).
model AuditLog {
  id        String      @id @default(cuid())
  userId    String? // null = acao de sistema/anonimo
  actorIp   String? // hash sha256 do IP (LGPD: nao raw)
  action    AuditAction
  target    String? // ex: "User:cuid123" pra qual recurso foi afetado
  meta      Json? // payload sanitizado
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

enum AuditAction {
  LOGIN
  LOGOUT
  PASSWORD_RESET
  ACCOUNT_CREATED
  ACCOUNT_DELETED
  DATA_EXPORTED
  CONSENT_GRANTED
  CONSENT_REVOKED
  PROFILE_UPDATED
  BILLING_SUBSCRIPTION_CREATED
  BILLING_SUBSCRIPTION_CANCELED
  BILLING_PAYMENT_FAILED
  CV_UPLOADED
  CV_DELETED
  LINKEDIN_RAW_REDACTED
  SECURITY_RATE_LIMIT_HIT
  SECURITY_BUDGET_EXCEEDED
  SECURITY_INVALID_WEBHOOK
  OUTCOME_REPORTED
  OUTCOME_SURVEY_SENT
  OUTCOME_SURVEY_DECLINED
  DAILY_BRIEFING_SENT
}

// Outcome: dataset proprietario pra calcular mediana real de contratados.
// Daniel + Bianca (Tera) cobraram esse dado. Sem outcomes, lib/metrics/median-stub
// e vaporware (HIRED_MEDIAN = 78 hardcoded). Cron de survey pergunta aos users
// 30/60/90 dias apos primeiro snapshot ("como esta a busca?"). Quando >=50
// outcomes HIRED, mediana stub vira mediana real do scoreAtTime.
//
// scoreAtTime + roleAtTime capturados no momento do reporte — correlaciona
// score historico com outcome (foi contratado com 65? 80? quais skills tinha?).
// surveyKind discrimina survey programado (30d/60d/90d) de self-reported (user
// decidiu reportar fora do milestone). evidence e texto livre OPCIONAL — sem
// PII obrigatorio, user descreve em prosa "consegui no Magalu, 2 meses".
//
// Cascade no userId pra "apagar minha conta" levar outcomes junto. Indices:
//  - (userId, occurredAt): timeline pessoal (debug, perfil do user).
//  - (kind, occurredAt): agregacao pra mediana real (groupBy kind, sample
//    do scoreAtTime).
model Outcome {
  id         String      @id @default(cuid())
  userId     String
  kind       OutcomeKind
  occurredAt DateTime    @default(now())

  // Snapshot do score no momento do reporte (do latest ScoreSnapshot do user
  // no momento do POST). Imutavel apos criacao — historiza pra correlacionar
  // score -> outcome mesmo que o user faca novo diagnostico depois.
  scoreAtTime Int?
  roleAtTime  String?

  // Contexto opcional. monthsSearching e int (clamped 0-60 no validator).
  // evidence e texto livre limitado (max 2000 chars) — SEM PII obrigatorio.
  monthsSearching Int?
  evidence        String? @db.Text

  // Discrimina survey programado (cron) de self-reported (user inicia).
  surveyKind SurveyKind?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([kind, occurredAt])
}

enum OutcomeKind {
  HIRED // contratado pra cargo-alvo
  HIRED_DIFFERENT // contratado pra cargo diferente
  NOT_HIRED // continua procurando (decisao explicita)
  STILL_LOOKING // ativo, sem decisao
  PAUSED // pausou busca (mudanca de vida, estudo)
  DECLINED_TO_ANSWER // user pulou survey (registra pra nao perguntar de novo)
}

enum SurveyKind {
  THIRTY_DAYS
  SIXTY_DAYS
  NINETY_DAYS
  SELF_REPORTED
}

// ============ Achievements (gamificacao sutil — feature #8 do STRATEGY_ROADMAP) ============

// Achievement: conquistas pontuais do user (primeiro diagnostico, 5 lacunas fechadas,
// score 80+, etc). Idempotente via unique (userId, kind) — segundo grant do mesmo
// kind retorna P2002 e ja sai com alreadyEarned. meta e Json opcional pra carregar
// contexto (ex: scoreAtTime, gapId). Cascade no userId pra "apagar minha conta"
// limpar junto. Indice (userId, earnedAt) atende a listagem cronologica em /conta.
model Achievement {
  id       String          @id @default(cuid())
  userId   String
  kind     AchievementKind
  earnedAt DateTime        @default(now())
  meta     Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId, earnedAt])
}

enum AchievementKind {
  FIRST_DIAGNOSIS
  FIRST_GAP_COMPLETED
  FIVE_GAPS_COMPLETED
  TEN_GAPS_COMPLETED
  FIRST_TAILOR
  FIRST_APPLICATION
  FIRST_INTERVIEW
  PROFILE_100_PERCENT
  ALL_ASSESSMENTS_COMPLETED
  STREAK_7_DAYS
  STREAK_30_DAYS
  SCORE_70
  SCORE_80
  SCORE_90
  FIRST_REFRESH
  FIRST_EVIDENCE
  COURSE_COMPLETED
}

// ============ Daily Quest (habit loop — feature #10 do STRATEGY_ROADMAP) ============

// DailyQuest: 1 acao curta sugerida AO DIA com base no estado do user. Razao
// concreta pra voltar. Lazy creation no GET (cria so quando o user pede) —
// sem cron, sem job em background. Unique (userId, questDate) garante 1 por
// dia (questDate e DATE sem hora). Cascade no userId pra "apagar minha conta"
// limpar junto. Indice (userId, completedAt) atende a listagem de historico
// e a heuristica de "kinds ja feitas nos ultimos 7 dias" (evita repeticao).
//
// NAO acoplado ao Achievement system — Wave 15 cobre conquistas automaticas.
// Aqui mantemos simples: marcar como feito so registra completedAt + rewardPoints
// (UI mostra confirmacao; nao explode em notificacao).
model DailyQuest {
  id               String    @id @default(cuid())
  userId           String
  questDate        DateTime  @db.Date // dia (sem hora) — unique por user/dia
  kind             QuestKind
  title            String
  description      String    @db.Text
  estimatedMinutes Int       @default(5)
  rewardPoints     Int       @default(5)
  completedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questDate])
  @@index([userId, completedAt])
}

enum QuestKind {
  CV_BULLET_REWRITE
  LINKEDIN_HEADLINE
  EVIDENCE_ADD
  SKILL_RESEARCH
  INTERVIEW_PREP
  NETWORK_OUTREACH
  MARKET_RESEARCH
  REFLECTION
}

// Funnel tracker semanal — caso Jamar Martins. User reporta volume por estagio
// (applications -> callbacks -> hmConversations -> finals -> offers) e o backend
// agrega/analisa o gargalo (analyzeBottleneck em lib/funnel.js).
//
// Audit Wave 11 (Treebeard v2 P0): callsites em app/api/funnel/route.js e
// app/(app)/funil/page.js usavam prisma.funnelEntry sem o model existir
// no schema. Adicionado pra fechar o gap — feature ja estava 100% codada.
//
// Unique (userId, weekStart) habilita upsert atomico que o POST usa pra
// permitir update da semana corrente. weekStart e sempre segunda 00:00 UTC
// calculada no servidor (anti-tampering via timestamp arbitrario).
//
// Indice (userId, weekStart DESC) acelera findMany ordenado das ultimas
// 12 semanas. Cascade no userId garante delete-account leva tudo junto.
model FunnelEntry {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime
  applications    Int      @default(0)
  callbacks       Int      @default(0)
  hmConversations Int      @default(0)
  finals          Int      @default(0)
  offers          Int      @default(0)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
}
