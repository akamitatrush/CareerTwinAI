// CareerTwin AI — schema inicial (Fase 1).
// PostgreSQL + Prisma. Auth.js v5 com adapter Prisma usa User/Account/Session/VerificationToken.
// Cascata em tudo que pendura de User → "Apagar tudo" é um único delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Auth.js (Prisma adapter) ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  profile      Profile?
  snapshots    ScoreSnapshot[]
  consents     Consent[]
  dataSources  DataSource[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ CareerTwin ============

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  nome        String?
  cargoAtual  String?
  senioridade String?
  targetRole  String?
  skills      String[] @default([])
  rawCv       String?  @db.Text
  perfilJson  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id         String   @id @default(cuid())
  userId     String
  role       String
  overall    Int
  subScores  Json
  perfilJson Json?
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gaps      Gap[]
  planItems PlanItem[]

  @@index([userId, createdAt])
}

model Gap {
  id              String    @id @default(cuid())
  snapshotId      String
  habilidade      String
  frequencia      String?
  porque          String?   @db.Text
  microacao       String?   @db.Text
  impactoDimensao String?
  impactoPontos   Int?
  completedAt     DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model PlanItem {
  id          String     @id @default(cuid())
  snapshotId  String
  semana      Int
  foco        String?
  titulo      String
  impacto     String?    @db.Text
  esforco     String?
  status      PlanStatus @default(pendente)
  completedAt DateTime?

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, semana])
}

enum PlanStatus {
  pendente
  feita
}

enum ConsentSource {
  CV_PASTE
  CV_PDF
  LINKEDIN_EXPORT
  LINKEDIN_OIDC
}

model Consent {
  id          String        @id @default(cuid())
  userId      String
  source      ConsentSource
  grantedAt   DateTime      @default(now())
  revokedAt   DateTime?
  payloadHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source])
}

model DataSource {
  id         String        @id @default(cuid())
  userId     String
  kind       ConsentSource
  label      String
  sizeBytes  Int?
  ingestedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ingestedAt])
}
