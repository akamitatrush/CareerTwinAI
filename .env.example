# ---- Provedor de IA ----
# "anthropic" (padrão) ou "openai"
LLM_PROVIDER=anthropic

# Modelo a usar. Para Anthropic, o recomendado é claude-sonnet-4-6.
# Para OpenAI, ex.: gpt-4o
LLM_MODEL=claude-sonnet-4-6

# ---- Chaves (preencha só a do provedor que você usa) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Banco de dados (Fase 1) ----
# Use o docker-compose para subir Postgres local: `docker compose up -d postgres`
DATABASE_URL="postgresql://careertwin:careertwin@localhost:5432/careertwin?schema=public"

# ---- Auth.js v5 (Fase 1) ----
# Gere com: openssl rand -base64 32
AUTH_SECRET=
# Em dev, AUTH_URL é detectado; em prod, defina:
# AUTH_URL=https://seu-dominio

# Email provider (magic link). Em dev usamos Mailpit via docker-compose.
# Mailpit SMTP: smtp://localhost:1025 (sem auth). UI: http://localhost:8025
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM="CareerTwin AI <nao-responder@careertwin.local>"

# LinkedIn OIDC (opcional — o provider só liga se ID/SECRET estiverem definidos)
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Em dev, habilita o provider Credentials "dev-only" (NÃO usar em produção).
# Travado no código por NODE_ENV !== "production".
AUTH_DEV_CREDENTIALS=false
