# ---- Provedor de IA ----
# "anthropic" (padrão) ou "openai"
LLM_PROVIDER=anthropic

# Modelo a usar. Para Anthropic, o recomendado é claude-sonnet-4-6.
# Para OpenAI, ex.: gpt-4o
LLM_MODEL=claude-sonnet-4-6

# LLM secundario rapido (Haiku 4.5 - 3-5x mais rapido + 1/4 do custo).
# Usado em rotas que fazem trabalho leve (parsing LinkedIn/portfolio,
# perguntas de entrevista, analise de bullets). Override aqui se quiser
# forcar outro modelo barato (ex.: gpt-4o-mini). Sem isso, default e Haiku.
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ---- Chaves (preencha só a do provedor que você usa) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- RAG real (pgvector + embeddings) ----
# Embeddings da knowledge base. Voyage AI e a recomendacao da Anthropic
# (voyage-3, 1024-dim, ~$0.06/1M tokens). Sem chave => fallback pra OPENAI_API_KEY
# (text-embedding-3-small truncado pra 1024-dim). Sem nenhum dos dois => RAG
# cai pra keyword puro (degradacao graceful).
# Pegue chave em https://www.voyageai.com/ — free tier 200M tokens.
VOYAGE_API_KEY=

# ---- Banco de dados (Fase 1) ----
# Use o docker-compose para subir Postgres local: `docker compose up -d postgres`
DATABASE_URL="postgresql://careertwin:careertwin@localhost:5432/careertwin?schema=public"

# ---- Auth.js v5 (Fase 1) ----
# Gere com: openssl rand -base64 32
AUTH_SECRET=
# Em dev, AUTH_URL é detectado; em prod, defina:
# AUTH_URL=https://seu-dominio

# Email provider (magic link).
# Em DEV: Mailpit via docker-compose. SMTP: smtp://localhost:1025 (sem auth).
#         UI captura em http://localhost:8025
# Em PROD: Resend (https://resend.com). Verifique o dominio em
#          Resend Dashboard → Domains, e use um EMAIL_FROM desse dominio.
#          Se AUTH_RESEND_KEY estiver setada, ela ganha sobre EMAIL_SERVER.
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM="CareerTwin AI <nao-responder@careertwin.local>"
AUTH_RESEND_KEY=

# ---- Monitoramento (Fase pitch) ----
# Segredo do cron weekly digest. Use openssl rand -hex 32.
# Vercel: Project Settings → Environment Variables → CRON_SECRET (encrypted).
# Vercel chama /api/cron/digest com header x-vercel-cron e voce precisa
# adicionar manualmente o header `x-cron-secret=<CRON_SECRET>` na config do cron.
CRON_SECRET=

# Salt pro hash sha256 do IP no AuditLog (LGPD: nao armazenamos IP raw).
# Use openssl rand -hex 32. Se mudar, perde-se a lincagem temporal entre IPs
# em registros antigos vs novos (cada salt produz hash diferente do mesmo IP).
AUDIT_IP_SALT=

# LinkedIn OIDC (opcional — o provider só liga se ID/SECRET estiverem definidos)
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Em dev, habilita o provider Credentials "dev-only" (NÃO usar em produção).
# Travado no código por NODE_ENV !== "production".
AUTH_DEV_CREDENTIALS=false

# ---- Vagas (Fase 2) ----
# Cada provider abaixo é OPCIONAL: sem chave, o conector simplesmente não entra
# na busca, e o app cai em vagas ILUSTRATIVAS rotuladas. Com chave, vagas reais
# aparecem com a fonte marcada na UI.

# Adzuna (https://developer.adzuna.com/) — cobertura BR boa, traz salário.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (https://jooble.org/api/about) — agregador.
JOOBLE_API_KEY=

# Greenhouse ATS — lista de boards públicos (slugs separados por vírgula).
# Ex.: GREENHOUSE_BOARDS=nubank,ifood,stone
GREENHOUSE_BOARDS=

# Lever ATS — lista de boards públicos (slugs separados por vírgula).
# Cobertura BR: Hotmart, Quero Educação, Onfly e várias scaleups que usam Lever.
# Ex.: LEVER_BOARDS=hotmart,quero,onfly
# Teste manual: https://api.lever.co/v0/postings/{slug}?mode=json
LEVER_BOARDS=

# Ashby ATS — lista de orgSlugs publicos. Cobertura BR: Loft, MercadoBitcoin,
# varias scaleups novas. Ex: ASHBY_BOARDS=loft,mercadobitcoin
# Teste: https://api.ashbyhq.com/posting-api/job-board/{slug}?includeCompensation=true
ASHBY_BOARDS=

# Workable ATS — lista de accounts publicos. Ex: WORKABLE_BOARDS=olist,onfly
# Teste: https://apply.workable.com/api/v3/accounts/{slug}/jobs?state=published
WORKABLE_BOARDS=

# ---- Observabilidade (v0.5) ----
# Sentry — sem DSN, o init é no-op (não envia nada). Crie projeto em
# sentry.io → Projects → Next.js, copie o DSN (público) e os identificadores
# de org/projeto pra source maps no deploy.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Opcional — pra publicar source maps no Sentry pelo build do Vercel.
SENTRY_AUTH_TOKEN=

# PostHog — sem KEY, o init é no-op. Crie projeto em posthog.com,
# copie a Project API Key (pública).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Rate-limit + cache distribuido (Upstash Redis) ----
# Em PROD (Vercel/serverless) e OBRIGATORIO setar essas duas vars — sem elas
# o sistema cai pra Map em-memoria por processo, que NAO funciona como defesa
# em multi-lambda (cada instancia zera o contador, bypass trivial). Em DEV
# single-node o Map funciona, entao pode deixar vazio.
#
# Setup gratuito (10k commands/dia):
# 1. Crie conta em https://upstash.com (login com Github).
# 2. Console -> Redis -> Create Database (regiao mais proxima dos lambdas).
# 3. Tab "REST API" -> copie UPSTASH_REDIS_REST_URL e UPSTASH_REDIS_REST_TOKEN.
# 4. Vercel: Project Settings -> Environment Variables -> Add (Production +
#    Preview). NAO setar em Development pra usar Map local.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Owner bypass (limites do plano Free) ----
# Lista de emails (comma-separated) que pegam plano pro_yearly direto, sem
# bater limites. Use pra testar produto sem rate-limit, equipe interna,
# dev local sem Stripe. Lookup case-insensitive + trim. Vazio = ninguem.
# Ex: OWNER_EMAILS=sergio@lognullsec.com,daniel@tera.com
OWNER_EMAILS=

# ---- Admin access (visao /admin com PII agregada) ----
# Separado de OWNER_EMAILS porque sao concerns diferentes:
#   - OWNER_EMAILS = equipe convidada (billing bypass, multiplas pessoas)
#   - ADMIN_EMAILS = founder (acesso a /admin, geralmente 1-2 emails)
# /admin e /api/admin/* checam isAdminEmail() — vazio = nao expoe rota.
# Lookup case-insensitive + trim. NUNCA mistura com OWNER_EMAILS.
# Ex: ADMIN_EMAILS=sergio@lognullsec.com,sergio@lognull.com
ADMIN_EMAILS=

# ---- Stripe (billing Phase 1+2) ----
# Sem STRIPE_SECRET_KEY, todos os endpoints de billing retornam 503 amigavel
# e o enforcement nao bloqueia nada (apenas track de uso continua funcionando).
# Setup completo: ver docs/MONETIZACAO.md.
#
# 1. Crie conta Stripe (test mode pra dev).
# 2. Stripe Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=
# 3. Stripe Dashboard → Developers → Webhooks → Add endpoint
#    → URL: https://seu-dominio/api/billing/webhook
#    → Eventos: checkout.session.completed, customer.subscription.*,
#               invoice.payment_succeeded, invoice.payment_failed
#    → Copie o Signing secret.
STRIPE_WEBHOOK_SECRET=
# 4. Stripe Dashboard → Products → cria 3 Prices (BRL):
#    - Pro mensal R$ 29 / month
#    - Pro anual  R$ 290 / year
#    - Team mensal R$ 99 / month (per seat)
#    Cole os price_xxx aqui:
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
