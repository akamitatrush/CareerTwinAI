# ---- Provedor de IA ----
# "anthropic" (padrão) ou "openai"
LLM_PROVIDER=anthropic

# Modelo a usar. Para Anthropic, o recomendado é claude-sonnet-4-6.
# Para OpenAI, ex.: gpt-4o
LLM_MODEL=claude-sonnet-4-6

# ---- Chaves (preencha só a do provedor que você usa) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- RAG real (pgvector + embeddings) ----
# Embeddings da knowledge base. Voyage AI e a recomendacao da Anthropic
# (voyage-3, 1024-dim, ~$0.06/1M tokens). Sem chave => fallback pra OPENAI_API_KEY
# (text-embedding-3-small truncado pra 1024-dim). Sem nenhum dos dois => RAG
# cai pra keyword puro (degradacao graceful).
# Pegue chave em https://www.voyageai.com/ — free tier 200M tokens.
VOYAGE_API_KEY=

# ---- Banco de dados (Fase 1) ----
# Use o docker-compose para subir Postgres local: `docker compose up -d postgres`
DATABASE_URL="postgresql://careertwin:careertwin@localhost:5432/careertwin?schema=public"

# ---- Auth.js v5 (Fase 1) ----
# Gere com: openssl rand -base64 32
AUTH_SECRET=
# Em dev, AUTH_URL é detectado; em prod, defina:
# AUTH_URL=https://seu-dominio

# Email provider (magic link).
# Em DEV: Mailpit via docker-compose. SMTP: smtp://localhost:1025 (sem auth).
#         UI captura em http://localhost:8025
# Em PROD: Resend (https://resend.com). Verifique o dominio em
#          Resend Dashboard → Domains, e use um EMAIL_FROM desse dominio.
#          Se AUTH_RESEND_KEY estiver setada, ela ganha sobre EMAIL_SERVER.
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM="CareerTwin AI <nao-responder@careertwin.local>"
AUTH_RESEND_KEY=

# ---- Monitoramento (Fase pitch) ----
# Segredo do cron weekly digest. Use openssl rand -hex 32.
# Vercel: Project Settings → Environment Variables → CRON_SECRET (encrypted).
# Vercel chama /api/cron/digest com header x-vercel-cron e voce precisa
# adicionar manualmente o header `x-cron-secret=<CRON_SECRET>` na config do cron.
CRON_SECRET=

# LinkedIn OIDC (opcional — o provider só liga se ID/SECRET estiverem definidos)
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Em dev, habilita o provider Credentials "dev-only" (NÃO usar em produção).
# Travado no código por NODE_ENV !== "production".
AUTH_DEV_CREDENTIALS=false

# ---- Vagas (Fase 2) ----
# Cada provider abaixo é OPCIONAL: sem chave, o conector simplesmente não entra
# na busca, e o app cai em vagas ILUSTRATIVAS rotuladas. Com chave, vagas reais
# aparecem com a fonte marcada na UI.

# Adzuna (https://developer.adzuna.com/) — cobertura BR boa, traz salário.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (https://jooble.org/api/about) — agregador.
JOOBLE_API_KEY=

# Greenhouse ATS — lista de boards públicos (slugs separados por vírgula).
# Ex.: GREENHOUSE_BOARDS=nubank,ifood,stone
GREENHOUSE_BOARDS=

# Lever ATS — lista de boards públicos (slugs separados por vírgula).
# Cobertura BR: Hotmart, Quero Educação, Onfly e várias scaleups que usam Lever.
# Ex.: LEVER_BOARDS=hotmart,quero,onfly
# Teste manual: https://api.lever.co/v0/postings/{slug}?mode=json
LEVER_BOARDS=

# Ashby ATS — lista de orgSlugs publicos. Cobertura BR: Loft, MercadoBitcoin,
# varias scaleups novas. Ex: ASHBY_BOARDS=loft,mercadobitcoin
# Teste: https://api.ashbyhq.com/posting-api/job-board/{slug}?includeCompensation=true
ASHBY_BOARDS=

# Workable ATS — lista de accounts publicos. Ex: WORKABLE_BOARDS=olist,onfly
# Teste: https://apply.workable.com/api/v3/accounts/{slug}/jobs?state=published
WORKABLE_BOARDS=

# ---- Observabilidade (v0.5) ----
# Sentry — sem DSN, o init é no-op (não envia nada). Crie projeto em
# sentry.io → Projects → Next.js, copie o DSN (público) e os identificadores
# de org/projeto pra source maps no deploy.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Opcional — pra publicar source maps no Sentry pelo build do Vercel.
SENTRY_AUTH_TOKEN=

# PostHog — sem KEY, o init é no-op. Crie projeto em posthog.com,
# copie a Project API Key (pública).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
