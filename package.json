    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.391.3",
    "prisma": "^6.19.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
